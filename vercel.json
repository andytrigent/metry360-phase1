{
  "name": "sojpe-c2h-dashboard",
  "version": 2,
  "public": false,
  "buildCommand": "echo 'Frontend ready'",
  "installCommand": "npm ci --prefer-offline",
  "env": {
    "API_BASE_URL": {
      "description": "Backend API base URL (AWS Lambda)",
      "default": "https://api.trigent-c2h.com"
    },
    "AWS_REGION": {
      "description": "AWS region for backend services",
      "default": "ap-south-1"
    }
  },
  "regions": ["iad1", "sin1"],
  "framework": "static",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
